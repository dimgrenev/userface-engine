{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@userface/engine": [
        "packages/engine/src/index.ts"
      ],
      "@userface/engine/*": [
        "packages/engine/*"
      ],
      "@userface/engine/face-ui": [
        "packages/engine/src/face-ui/index.ts"
      ],
      "@userface/engine/bundler": [
        "packages/engine/src/bundler/vfsBundler.ts"
      ],
      "@userface/engine/transpiler": [
        "packages/engine/src/transpiler.ts"
      ]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    "**/.artifacts"
  ]
}
