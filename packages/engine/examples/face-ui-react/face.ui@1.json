{
  "version": "ui@1",
  "meta": {
    "name": "face-ui-react example",
    "description": "Minimal ui@1 face.json that renders a small UI tree"
  },
  "root": {
    "type": "Panel",
    "props": {
      "left": "UI from face.ui@1.json",
      "right": { "$ref": "props.right" }
    },
    "children": [
      {
        "type": "Text",
        "props": { "text": "Hello from ui@1" }
      },
      {
        "type": "Button",
        "props": {
          "text": "Click",
          "variant": "accent",
          "onClick": { "$action": "log", "args": { "msg": "clicked" } }
        }
      }
    ]
  }
}


