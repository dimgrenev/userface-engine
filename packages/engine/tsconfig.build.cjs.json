{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/cjs",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": false,
    "emitDeclarationOnly": false
  },
  "exclude": [
    "src/**/*.test.*",
    "src/**/*.spec.*",
    "src/example-usage.ts",
    "dist",
    "../node_modules"
  ]
}


