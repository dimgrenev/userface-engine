{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://userface.dev/schemas/userface-proof@1.json",
  "title": "Userface Proof",
  "description": "Durable evidence that an AI UI change was checked against a repository design-system acceptance policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "status",
    "createdAt",
    "renderer",
    "repo",
    "target",
    "components",
    "validation",
    "composition",
    "preview",
    "patch",
    "agent",
    "egress",
    "pr",
    "summaries"
  ],
  "properties": {
    "schema": {
      "const": "userface-proof@1"
    },
    "id": {
      "type": "string",
      "pattern": "^ufp_[a-f0-9]{20}$"
    },
    "status": {
      "enum": [
        "blocked",
        "passed",
        "needs_input",
        "stale",
        "warning"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "userface-proof"
        },
        "version": {
          "type": "number"
        }
      }
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rootHash"
      ],
      "properties": {
        "rootHash": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "paths"
      ],
      "properties": {
        "kind": {
          "enum": [
            "readiness",
            "composition",
            "patch",
            "pr_gate",
            "trust"
          ]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "contracted",
        "used"
      ],
      "properties": {
        "total": {
          "type": "number",
          "minimum": 0
        },
        "contracted": {
          "type": "number",
          "minimum": 0
        },
        "used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "$ref": "#/$defs/check"
    },
    "composition": {
      "$ref": "#/$defs/check"
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "artifacts"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "not_run",
                  "unavailable"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "reason"
            ]
          }
        }
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "additions",
        "deletions"
      ],
      "properties": {
        "changeSetId": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "additions": {
          "type": "number",
          "minimum": 0
        },
        "deletions": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "attempts"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_run",
            "working",
            "repaired",
            "needs_input",
            "blocked"
          ]
        },
        "attempts": {
          "type": "number",
          "minimum": 0
        },
        "lastBlockingReason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "egress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "measurement",
        "modelCalls",
        "filesConsidered",
        "filesSent",
        "bytesSent",
        "absolutePathsSent",
        "remoteTelemetry",
        "network"
      ],
      "properties": {
        "mode": {
          "enum": [
            "offline",
            "local",
            "cloud"
          ]
        },
        "measurement": {
          "enum": [
            "zero_upload",
            "request_boundary",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "requestPayloadHash": {
          "type": "string",
          "minLength": 1
        },
        "modelCalls": {
          "type": "number",
          "minimum": 0
        },
        "estimatedInputTokens": {
          "type": "number",
          "minimum": 0
        },
        "filesConsidered": {
          "type": "number",
          "minimum": 0
        },
        "filesSent": {
          "type": "number",
          "minimum": 0
        },
        "bytesSent": {
          "type": "number",
          "minimum": 0
        },
        "contextItems": {
          "type": "number",
          "minimum": 0
        },
        "toolSchemaCount": {
          "type": "number",
          "minimum": 0
        },
        "totalRequestBytes": {
          "type": "number",
          "minimum": 0
        },
        "approvalCount": {
          "type": "number",
          "minimum": 0
        },
        "dataClasses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "absolutePathsSent": {
          "type": "boolean"
        },
        "remoteTelemetry": {
          "type": "boolean"
        },
        "network": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "measurement": {
                "const": "unavailable"
              }
            },
            "required": [
              "measurement"
            ]
          },
          "then": {
            "required": [
              "reason"
            ]
          }
        }
      ]
    },
    "pr": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "annotations"
      ],
      "properties": {
        "provider": {
          "enum": [
            "github",
            "none"
          ]
        },
        "annotations": {
          "type": "number",
          "minimum": 0
        },
        "summaryPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "checkStatus": {
      "enum": [
        "passed",
        "failed",
        "blocked",
        "stale",
        "not_run",
        "unavailable"
      ]
    },
    "severity": {
      "enum": [
        "error",
        "warning",
        "info"
      ]
    },
    "violation": {
      "type": "object",
      "required": [
        "ruleId",
        "description",
        "severity"
      ],
      "additionalProperties": true,
      "properties": {
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "violations"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "not_run",
                  "unavailable"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "reason"
            ]
          }
        }
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/violation"
          }
        }
      }
    }
  }
}
