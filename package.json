{
  "name": "userface-engine",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone workspace for @userface/engine and the userface umbrella CLI.",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --dir packages/engine build",
    "test": "pnpm build && pnpm exec vitest run --config vitest.config.ts --root .",
    "smoke": "pnpm --dir packages/engine smoke",
    "pack:packages": "node scripts/npm/pack-public-packages-dry.mjs",
    "smoke:public-cli": "pnpm build && node scripts/npm/smoke-public-cli-pack.mjs",
    "check": "pnpm test && pnpm smoke && pnpm run pack:packages && pnpm run smoke:public-cli",
    "publish:engine": "node scripts/npm/publish-public-packages.mjs @userface/engine",
    "publish:userface": "node scripts/npm/publish-public-packages.mjs userface",
    "publish:public": "node scripts/npm/publish-public-packages.mjs @userface/engine userface"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vue/server-renderer": "^3.5.19",
    "esbuild": "^0.25.9",
    "jsdom": "^26.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "svelte": "^5.55.7",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.3",
    "vitest": "^4.0.18",
    "vue": "^3.5.19",
    "@babel/parser": "^7.28.5"
  }
}
